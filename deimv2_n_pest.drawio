        <mxCell id="epa_c3d3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;endArrow=block;strokeColor=#7B1FA2;" edge="1" source="pan_c3" target="pan_u3b" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="epa_d3r4" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;endArrow=block;strokeColor=#7B1FA2;" edge="1" source="pan_u3b" target="pan_r4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="epa_fpn4p4" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=0.8;endArrow=block;strokeColor=#7B1FA2;dashed=1;dashPattern=4 2;" edge="1" source="fpn_c4" target="pan_r4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>


        <!-- ============================================================ -->
        <!-- RIGHT: DEIM Decoder Section -->
        <!-- ============================================================ -->
        <mxCell id="dec_lbl" value="DEIM Decoder" style="text;html=1;fontSize=11;align=center;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="538" y="162" width="82" height="16" as="geometry"/>
        </mxCell>

        <!-- Query Embedding -->
        <mxCell id="qe" value="Query Embedding&lt;br&gt;&lt;span style='font-size:8px'&gt;300 queries&lt;br&gt;learnable pos&lt;/span&gt;" style="rounded=1;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="532" y="184" width="100" height="42" as="geometry"/>
        </mxCell>

        <!-- Decoder Layer 1 -->
        <mxCell id="dl1" value="Decoder Layer 1&lt;br&gt;&lt;hr&gt;&lt;span style='font-size:8px'&gt;Self-Attn&lt;br&gt;Cross-Attn (D-FFN)&lt;br&gt;num_points=[4,4,2]&lt;/span&gt;" style="rounded=1;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1.5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="530" y="242" width="112" height="60" as="geometry"/>
        </mxCell>

        <!-- Decoder Layer 2 -->
        <mxCell id="dl2" value="Decoder Layer 2&lt;br&gt;&lt;hr&gt;&lt;span style='font-size:8px'&gt;Self-Attn + Cross-Attn&lt;br&gt;D-FFN (512 dim)&lt;/span&gt;" style="rounded=1;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1.5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="530" y="316" width="112" height="48" as="geometry"/>
        </mxCell>

        <!-- Decoder Layer 3 -->
        <mxCell id="dl3" value="Decoder Layer 3&lt;br&gt;&lt;hr&gt;&lt;span style='font-size:8px'&gt;Self-Attn + Cross-Attn&lt;br&gt;D-FFN + Output&lt;/span&gt;" style="rounded=1;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1.5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="530" y="380" width="112" height="48" as="geometry"/>
        </mxCell>

        <!-- Decoder connections -->
        <mxCell id="eqe_dl1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.3;endArrow=block;strokeColor=#C62828;" edge="1" source="qe" target="dl1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="edl1_dl2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.3;endArrow=block;strokeColor=#F57F17;" edge="1" source="dl1" target="dl2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="edl2_dl3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.3;endArrow=block;strokeColor=#F57F17;" edge="1" source="dl2" target="dl3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Cross-attention from encoder to all decoder layers (red dashed) -->
        <mxCell id="ee_d1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=0.8;endArrow=open;strokeColor=#D32F2F;dashed=1;dashPattern=4 3;" edge="1" source="pan_r3" target="dl1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ee_d2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=0.8;endArrow=open;strokeColor=#D32F2F;dashed=1;dashPattern=4 3;" edge="1" source="pan_r3" target="dl2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ee_d3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=0.8;endArrow=open;strokeColor=#D32F2F;dashed=1;dashPattern=4 3;" edge="1" source="pan_r3" target="dl3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>


        <!-- ============================================================ -->
        <!-- FAR RIGHT: Output Heads -->
        <!-- ============================================================ -->

        <!-- Classification Head -->
        <mxCell id="cls_h" value="Classification Head&lt;br&gt;&lt;hr&gt;&lt;span style='font-size:8px'&gt;4 classes&lt;br&gt;Focal Loss (α=0.75)&lt;/span&gt;" style="rounded=1;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=1.5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="674" y="250" width="106" height="46" as="geometry"/>
        </mxCell>

        <!-- Regression Head -->
        <mxCell id="reg_h" value="Regression Head&lt;br&gt;&lt;hr&gt;&lt;span style='font-size:8px'&gt;L1 Loss (w=5.0)&lt;br&gt;GIoU Loss (w=2.0)&lt;br&gt;DFL (w=1.5)&lt;/span&gt;" style="rounded=1;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=1.5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="674" y="308" width="106" height="56" as="geometry"/>
        </mxCell>

        <!-- Output Box -->
        <mxCell id="out_b" value="Output&lt;br&gt;&lt;hr&gt;&lt;span style='font-size:8px'&gt;Labels: (B, N)&lt;br&gt;Boxes: (B, N, 4)&lt;br&gt;Scores: (B, N)&lt;/span&gt;" style="rounded=1;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="682" y="382" width="88" height="56" as="geometry"/>
        </mxCell>

        <!-- Output connections -->
        <mxCell id="edl3_cls" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.3;endArrow=block;strokeColor=#388E3C;" edge="1" source="dl3" target="cls_h" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="edl3_reg" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.3;endArrow=block;strokeColor=#1976D2;" edge="1" source="dl3" target="reg_h" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ecls_out" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.3;endArrow=block;strokeColor=#7B1FA2;" edge="1" source="cls_h" target="out_b" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ereg_out" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.3;endArrow=block;strokeColor=#7B1FA2;" edge="1" source="reg_h" target="out_b" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

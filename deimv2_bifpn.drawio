        <mxCell id="e_p3_wff1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;endArrow=block;strokeColor=#7B1FA2;dashed=1;" edge="1" source="proj_p3" target="td_wff1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_wff1_conv1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.2;endArrow=block;strokeColor=#00796B;" edge="1" source="td_wff1" target="td_sepconv1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- P3_td -> Upsample -> W-Fuse(P2, P3_up) -->
        <mxCell id="e_p3up_up2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.2;endArrow=block;strokeColor=#EF6C00;" edge="1" source="td_sepconv1" target="td_up2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

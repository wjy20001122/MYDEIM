        <mxCell id="e_p2_wff2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;endArrow=block;strokeColor=#7B1FA2;dashed=1;" edge="1" source="proj_p2" target="td_wff2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_wff2_conv2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.2;endArrow=block;strokeColor=#00796B;" edge="1" source="td_wff2" target="td_sepconv2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>


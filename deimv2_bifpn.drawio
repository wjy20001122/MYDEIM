  C2f@stages=[1] n=1 e=0.25
  SPPFMicro@stage=3

&lt;b&gt;Encoder:&lt;/b&gt; LiteEncoderBiFPN
  in_ch=[256,512,1024]
  hidden_dim=112
  attention='ema'
  global_fusion=True
  expansion=0.34 depth=0.5

&lt;b&gt;Decoder:&lt;/b&gt; DEIMTransformer
  feat_ch=[112,112,112]
  nhead=8 num_queries=300
  dim_ffn=320 num_layers=3
  num_points=[4,4,2]

